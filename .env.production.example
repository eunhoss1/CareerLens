# EC2/RDS production-like example.
# This file is copied to the EC2 deploy directory as .env.production.
# Never commit real values.

DB_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/careerlens?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false
DB_USERNAME=<RDS_USERNAME>
DB_PASSWORD=<RDS_PASSWORD>
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_DDL_AUTO=update

JWT_SECRET=<LONG_RANDOM_SECRET>
JWT_ISSUER=careerlens
JWT_EXPIRATION_MINUTES=480
ADMIN_LOGIN_IDS=admin,careerlens-admin

CORS_ALLOWED_ORIGINS=http://<EC2_PUBLIC_IP>:3000
CORS_ALLOWED_ORIGIN_PATTERNS=http://<EC2_PUBLIC_IP>:*,https://*.example.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
AI_PLANNER_ENABLED=false

GREENHOUSE_ENABLED=true
GREENHOUSE_SYNC_ENABLED=false

DUFFEL_ENABLED=false
DUFFEL_ACCESS_TOKEN=
