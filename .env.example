# Copy this file to .env and fill in local secrets.
# .env is ignored by Git.

# Database
MYSQL_DATABASE=careerlens
MYSQL_ROOT_PASSWORD=1234
DB_URL=jdbc:mysql://db:3306/careerlens?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=1234
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_DDL_AUTO=update

# App
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
ADMIN_LOGIN_IDS=admin,careerlens-admin
JWT_SECRET=change-this-local-docker-secret-before-sharing

# AI planner / verification
AI_PROVIDER=openai
AI_PLANNER_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# Alternative AI provider
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_RESPONSES_URL=https://api.groq.com/openai/v1/responses

# Flight APIs
DUFFEL_ENABLED=false
DUFFEL_ACCESS_TOKEN=
DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_VERSION=v2
DUFFEL_SUPPLIER_TIMEOUT_MILLIS=10000

AMADEUS_ENABLED=false
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CURRENCY_CODE=KRW

# External job sync
GREENHOUSE_ENABLED=true
GREENHOUSE_SYNC_ENABLED=false
GREENHOUSE_SYNC_BOARD_TOKENS=airbnb,stripe,reddit,databricks,figma,greenhouse,anthropic,doordashusa,asana,discord,duolingo,gitlab,mixpanel,webflow
