# Local Docker Compose defaults.
# Copy to .env for local use. Do not commit real secrets.

MYSQL_DATABASE=careerlens
MYSQL_ROOT_PASSWORD=1234
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=3000

DB_DDL_AUTO=update
JWT_SECRET=change-this-to-a-long-random-secret-before-deploy

# Browser-facing API URL. For EC2 demo, use http://<EC2_PUBLIC_IP>:8080 or a real HTTPS API domain.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
AI_PLANNER_ENABLED=false

GREENHOUSE_SYNC_ENABLED=false

DUFFEL_ENABLED=false
DUFFEL_ACCESS_TOKEN=
